{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Foglamp",
  "description": "The missing observability layer for the Vercel AI SDK.",
  "colors": {
    "primary": "#171717",
    "light": "#FFFFFF",
    "dark": "#171717"
  },
  "favicon": "/images/favicon.png",
  "logo": {
    "light": "/images/wordmark-light.png",
    "dark": "/images/wordmark-dark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": ["introduction", "quickstart", "ai-instrument", "troubleshooting"]
          },
          {
            "group": "Core concepts",
            "pages": ["concepts/data-model"]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/overview",
              "sdk/configuration",
              "sdk/runtimes",
              "sdk/wrap"
            ]
          }
        ]
      },
      {
        "tab": "Dashboard",
        "groups": [
          {
            "group": "Explore",
            "pages": [
              "dashboard/overview",
              "dashboard/traces",
              "dashboard/workflows",
              "dashboard/agents",
              "dashboard/sessions"
            ]
          },
          {
            "group": "Operate",
            "pages": [
              "dashboard/alerts",
              "dashboard/evals",
              "dashboard/cost",
              "dashboard/account"
            ]
          }
        ]
      },
      {
        "tab": "Self-hosting",
        "groups": [
          {
            "group": "Self-hosting",
            "pages": [
              "self-hosting/overview",
              "self-hosting/configuration"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": ["changelog"]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API reference",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Ingest",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /ingest",
              "GET /health"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/foglamp-labs/foglamp"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/foglamp-labs/foglamp"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/foglamp-labs/foglamp"
    }
  },
  "icons": {
    "library": "tabler"
  },
  "background": {
    "color": {
      "light": "#FAFAFA",
      "dark": "#0F0F0F"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "thumbnails": {
    "fonts": {
      "family": "Inter"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "assistant",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ],
    "display": "header"
  },
  "seo": {
    "indexing": "navigable"
  },
  "integrations": {
    "posthog": {
      "apiKey": "phc_omfZbJqrCPpUndrTXtruEZvMZqde6Vqq8yP4dK6oJbzZ",
      "apiHost": "https://us.i.posthog.com",
      "sessionRecording": true
    }
  }
}
