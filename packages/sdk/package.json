{
  "name": "foglamp",
  "version": "0.0.1",
  "description": "Two-line observability for the Vercel AI SDK — costs, latency, tokens, and traces.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./wrap": {
      "types": "./dist/wrap/index.d.mts",
      "default": "./dist/wrap/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "uuidv7": "catalog:"
  },
  "peerDependencies": {
    "ai": "^4 || ^5 || ^6 || ^7.0.0-beta.1",
    "@vercel/functions": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@vercel/functions": {
      "optional": true
    }
  },
  "devDependencies": {
    "@foglamp/config": "workspace:*",
    "@foglamp/contracts": "workspace:*",
    "@types/bun": "catalog:",
    "@vercel/functions": "catalog:",
    "ai": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5",
    "zod": "catalog:"
  }
}
