{
  "name": "foglamp",
  "license": "Elastic-2.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "examples/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.13.4",
      "better-auth": "1.6.12",
      "@better-auth/stripe": "1.6.12",
      "stripe": "^22",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.13.4",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "ai": "7.0.0-beta.116",
      "@ai-sdk/openai": "4.0.0-beta.44",
      "@clickhouse/client": "^1.18.5",
      "@vercel/functions": "^3.6.0",
      "uuidv7": "^1.2.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "predev": "bun run dev:infra",
    "dev:infra": "docker compose up -d --wait postgres clickhouse",
    "dev:infra:down": "docker compose stop postgres clickhouse",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @foglamp/db db:push",
    "db:studio": "turbo -F @foglamp/db db:studio",
    "db:generate": "turbo -F @foglamp/db db:generate",
    "db:migrate": "turbo -F @foglamp/db db:migrate",
    "db:seed": "turbo -F server db:seed"
  },
  "dependencies": {
    "@foglamp/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@foglamp/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.19"
}
