# Base URL of the Hono/tRPC server. Client-exposed at build time.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional, SSR-only: in-cluster server URL (e.g. http://server:3000 in
# docker-compose) used when the web container can't reach the public host.
# INTERNAL_SERVER_URL=

# PostHog product analytics (optional). Leave the key unset to disable analytics
# entirely (no script loads, nothing is sent). The key is your PostHog *project*
# API key (starts with `phc_`). Host defaults to PostHog US cloud.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com