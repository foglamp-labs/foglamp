# Postgres connection string (API-key lookup)
DATABASE_URL=postgres://user:password@localhost:5432/foglamp

# Validated by the shared @foglamp/env/server schema on import. ingest does
# not use auth/email itself, but the single shared schema requires these — set
# them to the same values as apps/server. (Phase 8 makes the email vars
# optional so an email-less self-host can boot without a Resend key.)
BETTER_AUTH_SECRET=change-me-to-a-32+-character-random-secret
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
RESEND_API_KEY=re_xxxxxxxx

# --- ClickHouse (span store) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=foglamp

# --- Cost / pricing ---
OPENROUTER_MODELS_URL=https://openrouter.ai/api/v1/models
# Optional local pricing JSON for air-gapped deployments.
# FOGLAMP_PRICING_FILE=./pricing.json

# --- Ingest tuning ---
INGEST_PORT=4000
INGEST_FLUSH_INTERVAL_MS=1000
INGEST_FLUSH_MAX_ROWS=1000
INGEST_RATE_LIMIT_RPS=100
API_KEY_CACHE_TTL_MS=60000

NODE_ENV=development
