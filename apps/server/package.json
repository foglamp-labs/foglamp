{
  "name": "server",
  "license": "Elastic-2.0",
  "type": "module",
  "main": "dist/main.mjs",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/main.ts --outfile server",
    "dev": "bun run --hot src/main.ts",
    "db:seed": "bun run scripts/seed.ts",
    "start": "bun run dist/main.mjs"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.0",
    "@watchtower/api": "workspace:*",
    "@watchtower/auth": "workspace:*",
    "@watchtower/db": "workspace:*",
    "@watchtower/env": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "evlog": "^2.13.0",
    "hono": "catalog:",
    "uuidv7": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@watchtower/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
