# Postgres connection string (also read by drizzle-kit)
DATABASE_URL=postgres://user:password@localhost:5432/foglamp

# Better-Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Web app origin (primary). In prod, the apex/www domain where the client runs.
CORS_ORIGIN=http://localhost:3001

# Optional: extra trusted origins (comma or space separated).
# Useful for preview deploys, staging, etc.
# CORS_EXTRA_ORIGINS=https://preview-123.myapp.vercel.app,https://staging.myapp.com

RESEND_API_KEY=re_dabfdshfsdbbfsd
RESEND_FROM_EMAIL=anything@what.com

# --- ClickHouse (span store) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=foglamp

# --- Cost / pricing ---
OPENROUTER_MODELS_URL=https://openrouter.ai/api/v1/models
# Optional local pricing JSON for air-gapped deployments.
# FOGLAMP_PRICING_FILE=./pricing.json

# Span retention (days); applied via ALTER TABLE … MODIFY TTL on boot.
FOGLAMP_SPANS_RETENTION_DAYS=30

# --- Alerts (evaluator cron) ---
# How often enabled rules are swept (ms); default 60s.
ALERT_EVAL_INTERVAL_MS=60000
# Re-notify cooldown while a rule stays firing (ms); default 1h.
ALERT_RENOTIFY_MS=3600000

# --- Evals (scoring worker; BYOK judges) ---
# 32+ char secret that AES-256-GCM encrypts provider API keys at rest.
# REQUIRED to use evals/provider keys — leave unset to disable the feature.
# Generate with: openssl rand -base64 32
# FOGLAMP_SECRETS_KEY=
# How often the scoring worker sweeps enabled evals (ms); default 60s.
# SCORING_EVAL_INTERVAL_MS=60000
# Don't score spans newer than this (ms), so late spans settle first.
# SCORING_SETTLE_MS=60000
# Max judge LLM calls in flight, and max targets scored per eval per tick.
# EVAL_JUDGE_CONCURRENCY=5
# EVAL_SCORING_BATCH=100

# --- Optional Google OAuth (enabled only when both are present) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Seed script bootstrap (no static defaults; random printed once if unset) ---
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=

# --- Foggy (in-app AI assistant) ---
# Foggy is enabled only when GOOGLE_GENERATIVE_AI_API_KEY is set.
# GOOGLE_GENERATIVE_AI_API_KEY=
# FOGGY_MODEL=gemini-3.1-flash-lite
# Optional docs-search tool (Exa); the searchDocs tool no-ops without it.
# EXA_API_KEY=
# FOGGY_DOCS_URL=https://docs.foglamp.dev
# Cost guardrails.
# FOGGY_RPM=15
# FOGGY_DAILY_LIMIT=200
# FOGGY_MAX_STEPS=6
# FOGGY_MAX_OUTPUT_TOKENS=1500
# Optional: dogfood Foggy's own LLM calls into Foglamp (point at a project's key).
# FOGLAMP_API_KEY=
# FOGLAMP_INGEST_URL=http://localhost:4000/ingest

NODE_ENV=development
